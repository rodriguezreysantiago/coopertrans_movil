<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Storage legacy: en Android ≤12 (API ≤32) image_picker usa el
         Storage Access Framework legacy que necesita READ_EXTERNAL_STORAGE.
         Lo capamos a maxSdkVersion 32 para que en Android 13+ NO se pida
         (en 13+ usamos Photo Picker del sistema, ver abajo). El WRITE ya
         no se necesita en 13+ (scoped storage). -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- En Android 13+ NO declaramos READ_MEDIA_IMAGES / VIDEO / AUDIO.
         Google rechaza apps que no son galerías cuando los declaran
         (policy 2024): la app sólo sube fotos PUNTUALES de comprobantes
         (RTO, seguro, foto de perfil), no es una galería. image_picker
         1.0+ usa automáticamente el Photo Picker del sistema en API 33+
         cuando no hay permiso declarado — sin permission prompt para
         el usuario. tools:node="remove" excluye explícitamente cualquier
         declaración que algún plugin transitivo agregue al manifest
         mergeado. -->
    <uses-permission
        android:name="android.permission.READ_MEDIA_IMAGES"
        tools:node="remove" />
    <uses-permission
        android:name="android.permission.READ_MEDIA_VIDEO"
        tools:node="remove" />
    <uses-permission
        android:name="android.permission.READ_MEDIA_AUDIO"
        tools:node="remove" />

    <!-- Notificaciones runtime permission (Android 13+ / API 33).
         Sin esto flutter_local_notifications no puede mostrar avisos en
         celulares modernos aunque el canal est� creado. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Auto-arranque al boot para tablets dedicadas (kiosk Gomería).
         El BootReceiver escucha ACTION_BOOT_COMPLETED y lanza la app
         automáticamente cuando la tablet termina de bootear. Combinado
         con Pantalla Fija (Settings → Seguridad), el operador queda
         encerrado dentro de la app y la tablet siempre arranca con
         Coopertrans. Pedido Santiago 2026-06-09: Samsung One UI bloquea
         "app como Default Home", así que vamos por este camino que
         funciona en cualquier OEM sin ADB ni device owner. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- GPS para el bot�n "Usar mi ubicaci�n" del picker de ubicaciones
         de log�stica. Solo cuando la app est� en uso (no background).
         Privacy: el �nico uso es capturar coords manuales del operador
         al cargar un silo/planta nueva — no se trackea movimiento. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- C�mara: image_picker la usa cuando el chofer/admin elige
         "Tomar foto con la c�mara" para subir comprobantes o foto de perfil. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:label="Coopertrans Movil"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:extractNativeLibs="true"
        android:requestLegacyExternalStorage="true"
        android:hasCode="true"
        android:usesCleartextTraffic="false"> 
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- ════════════════════════════════════════════════════════════════
             KIOSK / SINGLE-APP MODE para tablets dedicadas (Gomería).
             ────────────────────────────────────────────────────────────────
             BootReceiver: auto-arranca la app cuando la tablet termina de
             bootear. Es la estrategia "kiosk para Samsung One UI" — el
             approach de "app como Default Home" (commit 08745da, descartado
             2026-06-09) NO funcionaba en Samsung con Android 13/14 porque
             Knox bloquea apps de terceros como Home.

             Setup en cada tablet nueva (sin ADB, sin device owner):
               1. Instalar el APK.
               2. Lanzar la app una vez (registra el BootReceiver).
               3. Settings → Seguridad → Pantalla fija → ON + PIN.
               4. Abrir Coopertrans → botón Recientes → fijar.
               5. Listo: al apagar/prender, arranca en Coopertrans; el
                  operador no puede salir sin el PIN.

             Funciona en cualquier OEM (Samsung incluido).
             ════════════════════════════════════════════════════════════════ -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED"/>
                <action android:name="android.intent.action.QUICKBOOT_POWERON"/>
            </intent-filter>
        </receiver>

        <!-- Activity-alias LEGACY (kiosk via "Default Home"). Quedó
             deshabilitado y se mantiene SOLO por compat de PCs/tablets que
             alguna vez lo hayan habilitado con ADB. El approach actual
             (BootReceiver arriba) no lo necesita. NO borrar sin revisar que
             ninguna tablet de campo lo tenga activo. -->
        <activity-alias
            android:name="com.coopertrans.movil.KioskHomeAlias"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:label="Coopertrans Movil">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.HOME"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
        </activity-alias>

        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>

    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="text/plain" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="text/csv" />
        </intent>
    </queries>
</manifest>
