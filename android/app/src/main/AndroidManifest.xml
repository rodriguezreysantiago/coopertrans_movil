<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Storage legacy: en Android ≤12 (API ≤32) image_picker usa el
         Storage Access Framework legacy que necesita READ_EXTERNAL_STORAGE.
         Lo capamos a maxSdkVersion 32 para que en Android 13+ NO se pida
         (en 13+ usamos Photo Picker del sistema, ver abajo). El WRITE ya
         no se necesita en 13+ (scoped storage). -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- En Android 13+ NO declaramos READ_MEDIA_IMAGES / VIDEO / AUDIO.
         Google rechaza apps que no son galerías cuando los declaran
         (policy 2024): la app sólo sube fotos PUNTUALES de comprobantes
         (RTO, seguro, foto de perfil), no es una galería. image_picker
         1.0+ usa automáticamente el Photo Picker del sistema en API 33+
         cuando no hay permiso declarado — sin permission prompt para
         el usuario. tools:node="remove" excluye explícitamente cualquier
         declaración que algún plugin transitivo agregue al manifest
         mergeado. -->
    <uses-permission
        android:name="android.permission.READ_MEDIA_IMAGES"
        tools:node="remove" />
    <uses-permission
        android:name="android.permission.READ_MEDIA_VIDEO"
        tools:node="remove" />
    <uses-permission
        android:name="android.permission.READ_MEDIA_AUDIO"
        tools:node="remove" />

    <!-- Notificaciones runtime permission (Android 13+ / API 33).
         Sin esto flutter_local_notifications no puede mostrar avisos en
         celulares modernos aunque el canal est� creado. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- GPS para el bot�n "Usar mi ubicaci�n" del picker de ubicaciones
         de log�stica. Solo cuando la app est� en uso (no background).
         Privacy: el �nico uso es capturar coords manuales del operador
         al cargar un silo/planta nueva — no se trackea movimiento. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- C�mara: image_picker la usa cuando el chofer/admin elige
         "Tomar foto con la c�mara" para subir comprobantes o foto de perfil. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:label="Coopertrans Movil"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:extractNativeLibs="true"
        android:requestLegacyExternalStorage="true"
        android:hasCode="true"
        android:usesCleartextTraffic="false"> 
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- ════════════════════════════════════════════════════════════════
             KIOSK / SINGLE-APP MODE para tablets dedicadas (ej. Gomería).
             ────────────────────────────────────────────────────────────────
             Activity-alias que vuelve a la app elegible como "Home"
             (CATEGORY_HOME). Deshabilitado por DEFAULT (android:enabled
             ="false") → en una instalación normal NO aparece en el chooser
             de launchers, no cambia nada para los choferes/admins comunes.

             Para activarlo SOLO en una tablet específica (con USB debugging
             habilitado), corremos un comando ADB:

               adb shell pm enable com.coopertrans.movil/com.coopertrans.movil.KioskHomeAlias

             Después en la tablet: Settings → Apps → Default apps → Home →
             Coopertrans Movil. Reiniciás → arranca derecho en la app, y
             el botón Home siempre vuelve a la app. Combinado con la
             "Pantalla fija" del sistema (Settings → Seguridad → ON + PIN
             para desfijar) el operador queda encerrado dentro de la app.

             Para revertir (volver la tablet al uso normal):
               adb shell pm disable-user com.coopertrans.movil/com.coopertrans.movil.KioskHomeAlias

             Pedido Santiago 2026-06-08 (tablet de Gomería).
             ════════════════════════════════════════════════════════════════ -->
        <activity-alias
            android:name="com.coopertrans.movil.KioskHomeAlias"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:label="Coopertrans Movil">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.HOME"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
        </activity-alias>

        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>

    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="text/plain" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="text/csv" />
        </intent>
    </queries>
</manifest>
