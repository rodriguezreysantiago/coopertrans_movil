<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Storage legacy: en Android ≤12 (API ≤32) image_picker usa el
         Storage Access Framework legacy que necesita READ_EXTERNAL_STORAGE.
         Lo capamos a maxSdkVersion 32 para que en Android 13+ NO se pida
         (en 13+ usamos Photo Picker del sistema, ver abajo). El WRITE ya
         no se necesita en 13+ (scoped storage). -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- En Android 13+ NO declaramos READ_MEDIA_IMAGES / VIDEO / AUDIO.
         Google rechaza apps que no son galerías cuando los declaran
         (policy 2024): la app sólo sube fotos PUNTUALES de comprobantes
         (RTO, seguro, foto de perfil), no es una galería. image_picker
         1.0+ usa automáticamente el Photo Picker del sistema en API 33+
         cuando no hay permiso declarado — sin permission prompt para
         el usuario. tools:node="remove" excluye explícitamente cualquier
         declaración que algún plugin transitivo agregue al manifest
         mergeado. -->
    <uses-permission
        android:name="android.permission.READ_MEDIA_IMAGES"
        tools:node="remove" />
    <uses-permission
        android:name="android.permission.READ_MEDIA_VIDEO"
        tools:node="remove" />
    <uses-permission
        android:name="android.permission.READ_MEDIA_AUDIO"
        tools:node="remove" />

    <!-- Notificaciones runtime permission (Android 13+ / API 33).
         Sin esto flutter_local_notifications no puede mostrar avisos en
         celulares modernos aunque el canal est� creado. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Auto-arranque al boot para tablets dedicadas (kiosk Gomería).
         El BootReceiver escucha ACTION_BOOT_COMPLETED y lanza la app
         automáticamente cuando la tablet termina de bootear. Combinado
         con Pantalla Fija (Settings → Seguridad), el operador queda
         encerrado dentro de la app y la tablet siempre arranca con
         Coopertrans. Pedido Santiago 2026-06-09: Samsung One UI bloquea
         "app como Default Home", así que vamos por este camino que
         funciona en cualquier OEM sin ADB ni device owner.

         SYSTEM_ALERT_WINDOW ("Mostrar sobre otras apps") es CLAVE para
         tablets Samsung: desde Android 10+, una app NO puede llamar
         startActivity() desde background sin restricciones, y eso
         bloquea al BootReceiver. Con este permiso activado manualmente
         por el admin (Settings → Apps → Coopertrans → Mostrar sobre
         otras apps), la app entra en la whitelist de "background
         activity start" y el BootReceiver puede lanzar la MainActivity.
         No se otorga automáticamente al instalar — es permiso "especial"
         que requiere ir a Settings una vez por tablet.

         WAKE_LOCK + REQUEST_IGNORE_BATTERY_OPTIMIZATIONS: la primera para
         FLAG_KEEP_SCREEN_ON (pantalla siempre encendida cuando la tablet
         está en modo Pantalla Fija — ver MainActivity); la segunda para
         que el admin pueda otorgar a Coopertrans la exención de
         optimización de batería. Sin la exención, Samsung One UI mete a
         la app en Doze tras varios minutos sin uso y el BootReceiver
         puede no recibir el broadcast después de un reinicio largo.
         (Settings → Apps → Coopertrans → Batería → Sin restricciones). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- GPS para el bot�n "Usar mi ubicaci�n" del picker de ubicaciones
         de log�stica. Solo cuando la app est� en uso (no background).
         Privacy: el �nico uso es capturar coords manuales del operador
         al cargar un silo/planta nueva — no se trackea movimiento. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- C�mara: image_picker la usa cuando el chofer/admin elige
         "Tomar foto con la c�mara" para subir comprobantes o foto de perfil. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:label="Coopertrans Movil"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:extractNativeLibs="true"
        android:requestLegacyExternalStorage="true"
        android:hasCode="true"
        android:usesCleartextTraffic="false"> 
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- ════════════════════════════════════════════════════════════════
             KIOSK / SINGLE-APP MODE para tablets dedicadas (Gomería).
             ────────────────────────────────────────────────────────────────
             BootReceiver: auto-arranca la app cuando la tablet termina de
             bootear. Es la estrategia "kiosk para Samsung One UI" — el
             approach de "app como Default Home" (commit 08745da, descartado
             2026-06-09) NO funcionaba en Samsung con Android 13/14 porque
             Knox bloquea apps de terceros como Home.

             directBootAware="true": necesario para que LOCKED_BOOT_COMPLETED
             (Android N+, Direct Boot) le llegue al receiver ANTES de que
             el usuario unlock la tablet. Sin esto, Android ignora ese
             action y queda solo BOOT_COMPLETED, que llega DESPUÉS del
             unlock (no apto si la tablet tiene PIN de pantalla — caso de
             la tablet Gomería, que NO va a tener PIN para que arranque
             sola). Marcarlo true es seguro: el receiver NO accede a
             archivos cifrados (solo llama startActivity).

             Setup completo en cada tablet nueva (sin ADB, sin device owner):
               1. Instalar el APK (Play Store o descarga directa).
               2. Lanzar la app UNA vez (Android 10+ bloquea broadcasts a
                  apps en "stopped state" hasta que el usuario las abre).
               3. Settings → Apps → Coopertrans → Permisos → Mostrar sobre
                  otras apps → ON (CLAVE para startActivity desde el
                  BootReceiver en Android 10+).
               4. Settings → Apps → Coopertrans → Batería → Sin restricciones
                  (en Samsung viene como "Optimizado" por defecto — eso
                  hace que el BootReceiver no reciba el broadcast).
               5. Settings → Display → Tiempo de espera → Nunca (o el máximo;
                  la app también activa FLAG_KEEP_SCREEN_ON cuando está
                  en Pantalla Fija, pero solo si la activity está en
                  foreground — antes de eso depende del setting).
               6. Settings → Lock screen → Tipo de bloqueo → Deslizar (sin
                  PIN; si la tablet tiene PIN, no puede arrancar sola
                  porque queda atrás del lockscreen).
               7. Settings → Seguridad → Pantalla fija → ON + PIN.
               8. Abrir Coopertrans → botón Recientes → fijar la app.
               9. Listo: al apagar/prender, arranca en Coopertrans; el
                  operador no puede salir sin el PIN.

             Funciona en cualquier OEM (Samsung incluido).
             ════════════════════════════════════════════════════════════════ -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true"
            android:enabled="true"
            android:directBootAware="true">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED"/>
                <action android:name="android.intent.action.QUICKBOOT_POWERON"/>
            </intent-filter>
        </receiver>

        <!-- ════════════════════════════════════════════════════════════════
             KIOSK DURO (Device Owner) — tablet de Gomería.
             ────────────────────────────────────────────────────────────────
             KioskDeviceAdminReceiver es el componente al que apunta el
             provisioning por ADB (una vez por tablet, reseteada de fábrica y
             SIN cuenta de Google):

               adb shell dpm set-device-owner \
                 com.coopertrans.movil/.KioskDeviceAdminReceiver

             Una vez Device Owner, MainActivity entra en lock task mode REAL
             (sobrevive reinicios, el operador no puede salir) y se fija como
             Home preferido. NO afecta a celulares de choferes comunes: si la
             app no es Device Owner, MainActivity no toca nada.

             El permiso BIND_DEVICE_ADMIN lo exige el sistema para el receiver.
             ════════════════════════════════════════════════════════════════ -->
        <receiver
            android:name=".KioskDeviceAdminReceiver"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <!-- Resultado de la instalación silenciosa del auto-update kiosk
             (Fase 2). PackageInstaller.commit() lo usa como IntentSender. No
             exportado: solo lo dispara el sistema para nuestra propia sesión. -->
        <receiver
            android:name=".KioskInstallResultReceiver"
            android:exported="false" />

        <!-- Activity-alias del kiosk via "Default Home". Queda DISABLED en el
             manifest; MainActivity lo habilita en runtime SOLO si la app es
             Device Owner (así los choferes comunes nunca ven a Coopertrans
             ofrecida como launcher). El Device Owner lo fija como Home
             preferido programáticamente — Knox NO lo bloquea por ese camino,
             al revés que el intento manual de "Default Home". NO borrar sin
             revisar que ninguna tablet de campo lo tenga activo. -->
        <activity-alias
            android:name="com.coopertrans.movil.KioskHomeAlias"
            android:targetActivity=".MainActivity"
            android:enabled="false"
            android:exported="true"
            android:label="Coopertrans Movil">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.HOME"/>
                <category android:name="android.intent.category.DEFAULT"/>
            </intent-filter>
        </activity-alias>

        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>

    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <intent>
            <action android:name="android.intent.action.SEND" />
            <data android:mimeType="text/plain" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="text/csv" />
        </intent>
    </queries>
</manifest>
