<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIconFile</key>
	<string></string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.business</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>NSHumanReadableCopyright</key>
	<string>$(PRODUCT_COPYRIGHT)</string>
	<key>NSMainNibFile</key>
	<string>MainMenu</string>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>

	<!-- ─── Purpose strings (obligatorias para App Store macOS) ─── -->
	<!-- Apple las muestra al usuario la PRIMERA vez que un sandbox flag
	     dispara el prompt. Si están vacías o faltan, el sandbox NO
	     concede el permiso y la feature queda muda. -->

	<key>NSLocationUsageDescription</key>
	<string>Coopertrans usa la ubicación para autocompletar coordenadas cuando el operador carga una nueva ubicación logística (silos, plantas, depósitos).</string>

	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Coopertrans usa la ubicación para autocompletar coordenadas cuando el operador carga una nueva ubicación logística.</string>

	<key>NSDesktopFolderUsageDescription</key>
	<string>Coopertrans puede guardar reportes Excel en el escritorio si elegís esa carpeta.</string>

	<key>NSDocumentsFolderUsageDescription</key>
	<string>Coopertrans puede guardar reportes Excel en Documentos si elegís esa carpeta.</string>

	<key>NSDownloadsFolderUsageDescription</key>
	<string>Coopertrans guarda los reportes Excel exportados en Descargas para que los abras desde Finder.</string>

	<!-- ─── App appearance ─── -->
	<!-- Coopertrans Móvil tiene tema oscuro (fondo cobalto profundo).
	     NSAppearance=DarkAqua fuerza dark mode REAL en el title bar y los
	     menúes nativos macOS, así combinan con la app y no se ve un AppBar
	     oscuro pegado a un title bar claro. (NSRequiresAquaSystemAppearance
	     solo habilita seguir al sistema; NO fuerza dark — por eso hace falta
	     NSAppearance.) -->
	<key>NSAppearance</key>
	<string>NSAppearanceNameDarkAqua</string>
	<key>NSRequiresAquaSystemAppearance</key>
	<false/>

	<!-- Export compliance: la app solo usa cifrado estándar del OS (HTTPS) →
	     EXENTA. Sin esta key, App Store Connect deja el build esperando el
	     "Cumplimiento de exportación" y no llega a TestFlight (deja el paso de
	     Xcode Cloud colgado). Mismo valor que iOS. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
