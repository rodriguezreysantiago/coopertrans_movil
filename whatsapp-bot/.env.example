# Copiar a `.env` y completar con valores reales (.env está en gitignore).

# ─── Identidad de esta PC (importante para multi-PC) ───
# Cada PC donde corra el bot debe tener un BOT_PC_ID único — por
# ejemplo "casa", "oficina", "server-prod". Lo usa el bot al arrancar
# para detectar si OTRA PC ya está corriendo el bot (lee BOT_HEALTH/main
# en Firestore) y, si es así, aborta para evitar dos bots procesando
# la misma cola (lo que dispararía mensajes duplicados y posible
# baneo del número de WhatsApp).
#
# Si no se setea, el bot usa el hostname del SO como fallback
# (ej. "DESKTOP-XYZ123"), pero conviene poner algo legible.
BOT_PC_ID=casa

# Número de WhatsApp del bot (solo dígitos, formato 549...). Refuerzo
# anti-auto-mensaje: el bot descarta entrantes de su PROPIO número y nunca
# se envía un mensaje a sí mismo, aunque la metadata fromMe falle (pasa en
# sesiones recién vinculadas, ej. al cambiar el dispositivo del bot).
# BOT_PHONE=549XXXXXXXXXX

# Bypass del check anti-doble-bot. Solo poner true si SABÉS que la
# otra PC está muerta y el heartbeat es residual. Default: false.
# FORCE_START=false

# Umbral en segundos para considerar el último heartbeat como
# "fresco" (= la otra PC está viva). Default 150 (2.5x el intervalo
# default de heartbeat de 60s). Bajalo si querés que el lock se
# libere más rápido cuando la otra PC se muere abruptamente.
# UMBRAL_OTRA_INSTANCIA_SEG=150

# Ruta absoluta o relativa al service account key de Firebase.
# El proyecto principal ya tiene uno en `../serviceAccountKey.json`
# (raíz del repo). Si querés, copialo al lado de este package.json y
# usa "./serviceAccountKey.json" para no depender del path padre.
FIREBASE_CREDENTIALS_PATH=../serviceAccountKey.json

# ID del proyecto Firebase. Útil si el service account no lo expone.
FIREBASE_PROJECT_ID=coopertrans-movil

# Bucket de Firebase Storage (donde el bot sube las fotos que mandan
# los choferes en la Fase 3). Default: `<projectId>.appspot.com`
# (legacy). Si tu proyecto se creó después de Oct 2024, podría ser
# `<projectId>.firebasestorage.app` — chequealo en la consola de
# Firebase si las subidas fallan.
# FIREBASE_STORAGE_BUCKET=coopertrans-movil.firebasestorage.app

# ─── Aviso diario consolidado de service preventivo ───
# DNI del empleado que recibe el reporte diario de service de tractores.
# Va consolidado en UN solo mensaje (no se manda al chofer de cada
# tractor para evitar spam — el chofer ya recibe avisos de papeles).
# Si NO se setea, no se envía el aviso de service diario.
# Default operativo: 29820141 (Emmanuel Corchete, área mantenimiento).
SERVICE_DESTINATARIO_DNI=29820141

# ─── Resumen diario de mantenimiento Volvo (OBSOLETO desde 2026-05-22) ───
# Hasta el 2026-05-22 esta var disparaba el "Resumen diario — Alertas de
# mantenimiento" que el bot le mandaba al Jefe de Mantenimiento. Ese resumen
# le llegaba DUPLICADO con el "Parte de mantenimiento" que arma la Cloud
# Function `resumenMantenimientoVehiculosDiario` (testigos del tablero +
# eventos de neumáticos/tacógrafo). Se eliminó el del bot; ahora SOLO manda
# el Parte de la CF, cuyo destinatario es MANTENIMIENTO_VEHICULOS_DNI
# (hardcodeado en functions/src/comun.ts = 29820141, mismo Emmanuel).
#
# Esta var YA NO dispara ningún envío. Se mantiene sólo porque health.js la
# publica en el heartbeat para la pantalla "Estado del Bot" (pendiente de
# limpiar). Cambiarla acá NO reenruta el Parte — eso se hace en comun.ts.
ALERTAS_RESUMEN_DESTINATARIO_DNI=29820141

# ─── Resumen diario de Alertas Volvo HIGH (Seg e Higiene) ───
# DNI del Jefe de Seg e Higiene que recibe el resumen diario consolidado
# de Alertas Volvo de severidad HIGH (cron_alertas_volvo_resumen en
# src/cron.js). Va a una persona distinta del jefe de mantenimiento
# porque el mantenimiento es responsabilidad de otra área.
#
# Si NO se setea, fallback al DNI histórico hardcodeado en cron.js
# (34730329 = Molina al 2026-05-07) para que la rotación no rompa
# producción si alguien olvida configurar la env var.
#
# Default operativo: 34730329 (Molina, Jefe Seg e Higiene).
ALERTAS_SEG_HIGIENE_DESTINATARIO_DNI=34730329

# ─── Resumen diario de vencimientos próximos (≤7 días) ───
# DNI del encargado de documentación. Recibe 1 mensaje por día con
# TODO lo que vence en los próximos 7 días: legajo de cada chofer
# (Licencia, Preocupacional, Manejo Defensivo), papeles de cada
# unidad (RTO, Seguro, Extintores cuando aplica) y los 4 docs de
# cada empresa empleadora (Póliza ART, F. 931, SCVO, Libre deuda
# sindical). Si no hay nada que vence, no se envía mensaje.
#
# Si NO se setea, el resumen no se envía.
# Default operativo: 26456455 (Giagante Guillermo, encargado de documentación).
DOCUMENTACION_DESTINATARIO_DNI=26456455

# ─── Aviso temprano al ADMIN de docs por empresa próximos a vencer ───
# DNI del admin que recibe diariamente un aviso de los docs por empresa
# (Póliza ART, F.931, SCVO, Libre deuda sindical) que vencen en próximos
# 30 días. Umbral más amplio que el de Giagante (7 días) — el admin lo
# recibe primero para coordinar con Giagante antes de que sea urgente.
# Si NO se setea, default es 35244439 (Santiago, hardcoded en cron.js).
EMPRESA_DOCS_ADMIN_DNI=35244439

# ─── Comportamiento humano del bot (anti-baneo) ───
# Ventana de envío. La zona horaria es CRÍTICA — no usamos la del server
# (puede ser UTC o cambiar). Forzamos Buenos Aires con WORKING_TIMEZONE.
#
# Lunes a viernes: ventana START a END (END=24 = hasta las 23:59).
# Sábado: ventana SAT_START a SAT_END. Si SAT_END=0 (default), sábado
#   no manda — preserva el comportamiento histórico del bot.
# Domingo: hardcodeado skip (no configurable, mandar domingo dispara
#   baneo de WhatsApp).
# Feriados nacionales AR: hardcodeado skip (lista en feriados_ar.js).
WORKING_HOURS_START=8
WORKING_HOURS_END=24
WORKING_HOURS_SAT_START=8
WORKING_HOURS_SAT_END=12
WORKING_TIMEZONE=America/Argentina/Buenos_Aires

# Delay aleatorio entre mensajes — uniformemente entre estos extremos.
# 15-60 segundos es conservador pero seguro; subir si querés más cautela.
DELAY_MIN_MS=15000
DELAY_MAX_MS=60000

# Cantidad máxima de mensajes por hora. Si la cola tiene más, los
# distribuye en la siguiente hora. Mantener bajo.
MAX_MESSAGES_PER_HOUR=30

# ─── Reintentos automáticos ───
# Cuando un envío falla por un error TRANSITORIO (timeout, red, sesión
# WA caída), el bot lo reintenta con backoff exponencial en lugar de
# marcarlo como ERROR definitivo. Errores DEFINITIVOS (teléfono
# inválido, número sin WhatsApp) van directo a ERROR — no se reintentan.
#
# MAX_RETRIES: cantidad máxima de reintentos transitorios antes de
# escalar a ERROR. Después del MAX, el doc queda en ERROR aunque el
# error siga siendo transitorio.
#
# RETRY_BACKOFF_SEC: lista CSV de segundos a esperar entre intentos.
# Default "30,120,600" = 30s, 2 min, 10 min. Si la lista tiene menos
# items que MAX_RETRIES, el último valor se reusa.
MAX_RETRIES=3
RETRY_BACKOFF_SEC=30,120,600

# ─── Watchdog del cliente WhatsApp ───
# Bug conocido: a veces después de `authenticated` el evento `ready`
# nunca llega (A/B testing de WhatsApp del lado servidor). Para que el
# bot no quede co
# ─── Alerta cola creciente (anti "bot lento sin caer") ───
# Si la cola pendiente supera UMBRAL docs sostenidos por más de
# MIN_SOSTENIDO minutos, el bot encola una alerta al ALERT_DNI.
# Sin ALERT_DNI, el feature está apagado (no manda nada).
# COLA_CRECIENTE_ALERT_DNI=35244439
COLA_CRECIENTE_UMBRAL=50
COLA_CRECIENTE_MIN_SOSTENIDO=30

# ─── Backup automático de la sesión WhatsApp ───
# Comprime .wwebjs_auth/ a un .zip y lo sube a Cloud Storage cada
# INTERVAL_HOURS. Si la PC se rompe físicamente, recuperás la sesión
# bajando el último zip — sin re-escanear QR. Retención automática.
WWEBJS_BACKUP_ENABLED=false
WWEBJS_BACKUP_BUCKET=coopertrans-movil-backups
WWEBJS_BACKUP_INTERVAL_HOURS=24
WWEBJS_BACKUP_RETENTION_DAYS=30

# ─── Agente conversacional (IA) — Google Gemini ───
# Asistente que responde por WhatsApp las preguntas de los choferes en
# lenguaje natural (vencimientos, unidad asignada, jornada...) consultando
# datos REALES de Firestore. APAGADO por default — no hace nada sin API
# key + flag de Firestore.
#
# Proveedor: Google Gemini. Antes había multi-proveedor (Gemini + Anthropic
# Claude como fallback + Groq Llama un tiempo); se simplificó a Gemini
# único el 2026-06-08 cuando Santiago contrató el plan paga de Gemini.
#
# Setup:
#   1. Generá una API key en aistudio.google.com.
#   2. Pegala en GEMINI_API_KEY.
#   3. Encendé con AGENTE_ENABLED=true (o META/config_bot.agente_activo=true).
GEMINI_API_KEY=
# Modelo Gemini. Default `gemini-2.5-flash`. Cambiá si querés probar un id
# distinto (p.ej. `gemini-2.0-pro` para casos más complejos a más costo).
# AGENTE_MODELO_GEMINI=gemini-2.5-flash
#
# Encendido. true/false explícito gana; si lo dejás VACÍO manda el flag de
# Firestore META/config_bot.agente_activo (default: apagado).
# AGENTE_ENABLED=
# Tope de preguntas por chofer por hora (anti-spam / anti-costo). Default 20.
# AGENTE_MAX_POR_HORA=20
# DNI del admin que recibe un WhatsApp si el agente se queda SIN cuota de
# Gemini (error 429). Si no se setea, usa COLA_CRECIENTE_ALERT_DNI. Throttle 6h.
# AGENTE_SIN_SALDO_ALERT_DNI=
# Timeout de la llamada a la API en ms. Default 30000.
# AGENTE_TIMEOUT_MS=30000
# Backoff antes del único retry ante 429 (ms). Default 3500 — los rate-limits
# por minuto se liberan rápido. Si subís el tope de tráfico, bajalo.
# AGENTE_RETRY_429_MS=3500
