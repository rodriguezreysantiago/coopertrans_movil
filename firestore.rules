// Firestore Security Rules вЂ” Coopertrans MГіvil
//
// Modelo de auth:
//   La app usa Firebase Auth con custom tokens emitidos por la
//   Cloud Function `loginConDni`. El UID es el DNI del chofer y el
//   rol viaja como CUSTOM CLAIM en el JWT (`request.auth.token.rol`).
//   Eso permite chequear `isAdmin()` SIN tocar Firestore en cada
//   regla (ahorra una lectura por regla y por documento).
//
// Convenciones:
//   - `isSignedIn()`: usuario logueado (cualquier rol).
//   - `isAdmin()`: rol = 'ADMIN' en el custom claim.
//   - `isSelf(dni)`: el UID del JWT coincide con el dni del path.
//
// IMPORTANTE: si un admin cambia el ROL de un chofer en `EMPLEADOS`,
//   el custom claim queda desactualizado hasta el prГіximo login. Si
//   se necesita propagar mГЎs rГЎpido, el cliente puede forzar
//   `await currentUser.getIdToken(true)` despuГ©s de un cambio.
//
// DEPLOY:
//   firebase deploy --only firestore:rules

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========================================================================
    // FUNCIONES DE PERMISOS
    // ========================================================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.rol == 'ADMIN';
    }

    /// Mando medio: gestiona personal, flota, vencimientos, revisiones,
    /// bot. NO puede crear admins ni cambiar roles. Usar
    /// `isAdminOrSupervisor()` para reglas que ambos pueden.
    function isSupervisor() {
      return isSignedIn() && request.auth.token.rol == 'SUPERVISOR';
    }

    /// Helper combinado вЂ” la mayorГ­a de reglas del panel admin
    /// (escritura de EMPLEADOS, VEHICULOS, REVISIONES, etc) aplican
    /// a ambos roles.
    function isAdminOrSupervisor() {
      return isAdmin() || isSupervisor();
    }

    /// Rol especializado: gomero/encargado de cubiertas. Opera SOLO
    /// el mГіdulo GomerГ­a (alta de cubiertas, instalaciГіn, recapado).
    function isGomeria() {
      return isSignedIn() && request.auth.token.rol == 'GOMERIA';
    }

    /// Rol especializado: Seguridad e Higiene. Monitorea conducta y
    /// eventos Volvo (alertas, eco-driving, descargas PTO, mapa).
    function isSegHigiene() {
      return isSignedIn() && request.auth.token.rol == 'SEG_HIGIENE';
    }

    /// QuiГ©nes pueden operar el mГіdulo GomerГ­a: admin/supervisor +
    /// el rol especializado GOMERIA.
    function puedeOperarGomeria() {
      return isAdminOrSupervisor() || isGomeria();
    }

    /// QuiГ©nes pueden ver los tableros Volvo (alertas, eco-driving,
    /// descargas PTO, mapa de eventos): admin/supervisor + SEG_HIGIENE.
    function puedeVerVolvoTableros() {
      return isAdminOrSupervisor() || isSegHigiene();
    }

    function isSelf(dni) {
      return isSignedIn() && request.auth.uid == dni;
    }

    /// True si la patente es la unidad asignada al chofer logueado.
    /// Hace un lookup adicional a EMPLEADOS/{uid} вЂ” costo de 1 read extra
    /// por cada lectura de VEHICULOS por parte de un chofer (el costo es
    /// aceptable porque la pantalla "Mi equipo" del chofer hace 1-2 lecturas
    /// por sesiГіn, no es hot path).
    /// Cubre tanto el campo VEHICULO (tractor) como ENGANCHE.
    function isMyAssignedVehiculo(patente) {
      return isSignedIn()
        && (
          get(/databases/$(database)/documents/EMPLEADOS/$(request.auth.uid)).data.VEHICULO == patente
          || get(/databases/$(database)/documents/EMPLEADOS/$(request.auth.uid)).data.ENGANCHE == patente
        );
    }

    // ========================================================================
    // EMPLEADOS вЂ” cada chofer ve su propio legajo; el admin ve todos
    // ========================================================================

    match /EMPLEADOS/{dni} {
      // Lectura: el dueГ±o puede ver su legajo, admin/supervisor todos.
      // SEG_HIGIENE tambiГ©n вЂ” necesita resolver DNI в†’ nombre en el mГіdulo
      // ICM (icm_ranking_screen, icm_detalle_chofer_screen) y en el mapa
      // Volvo para mostrar quien manejaba cuando ocurrio un evento.
      //
      // NOTA SOBRE CONTRASEГ‘A (auditoria 2026-05-17): Firestore NO
      // soporta field-level security. La rule permite al chofer leer
      // SU doc entero, incluido el hash bcrypt. Si un chofer hostil
      // toma el JWT y baja su doc, podria hacer brute-force OFFLINE
      // contra el hash (bcrypt cost 10 в‰€ 100ms/intento вЂ” viable para
      // passwords debiles). MITIGACION FUTURA: mover CONTRASEГ‘A a
      // subcoleccion `EMPLEADOS/{dni}/credenciales/main` con
      // `read: if false`. Por ahora, la validacion de password fuerza
      // minimo 6 chars al alta + comentario aqui para no olvidar.
      allow read: if isAdminOrSupervisor() || isSegHigiene() || isSelf(dni);
      // Crear y borrar: solo admin/supervisor (alta y baja).
      allow create, delete: if isAdminOrSupervisor();
      // Update: admin/supervisor sin restricciГіn.
      // El chofer (dueГ±o del legajo) puede actualizar SOLO los campos
      // self-service de "Mi Perfil":
      //   - ARCHIVO_PERFIL: foto de perfil (sube nueva foto y actualiza URL).
      //   - TELEFONO / MAIL: datos personales que el chofer puede actualizar
      //     desde la pantalla "Datos personales" de Mi Perfil. Si los omitimos
      //     acГЎ, la edicion tira permission-denied silencioso y rompe la UX.
      // CRITICO (auditoria 2026-05-17): CONTRASEГ‘A REMOVIDA de la
      // whitelist. Antes un atacante con device fisico (turno
      // compartido, dispositivo robado) podia entrar al perfil y
      // cambiar el hash directo desde DevTools / cliente Firestore
      // custom sin validar la contraseГ±a actual. Ahora el cambio de
      // pass DEBE pasar por la callable `cambiarContraseГ±aChofer`
      // que valida server-side la actual con bcrypt antes de aceptar
      // el nuevo hash (ver functions/src/index.ts).
      // Cualquier otro campo (DNI, rol, vencimientos, vehГ­culo asignado,
      // etc.) estГЎ reservado a admin/supervisor.
      allow update: if isAdminOrSupervisor()
        || (isSelf(dni)
            && request.resource.data.diff(resource.data)
                 .affectedKeys().hasOnly(['ARCHIVO_PERFIL',
                                          'TELEFONO', 'MAIL']));
    }

    // ========================================================================
    // VEHICULOS вЂ” cualquier logueado lee, solo admin escribe
    // ========================================================================

    match /VEHICULOS/{patente} {
      // Lectura general: admin/supervisor + roles operativos que necesitan
      // el catГЎlogo completo (SEG_HIGIENE para vincular eventos Volvo a
      // patente, GOMERIA para mostrar en quГ© tractor estГЎ cada cubierta).
      // El chofer solo puede leer SU patente asignada (tractor o enganche)
      // вЂ” antes leГ­a toda la flota, ahora restringido para no exponer
      // KMs/combustible/autonomГ­a de unidades ajenas (info comercial).
      allow read: if isAdminOrSupervisor()
        || isSegHigiene()
        || isGomeria()
        || isMyAssignedVehiculo(patente);
      // Alta, ediciГіn, sincronizaciГіn Volvo (KM/combustible/autonomГ­a):
      // admin o supervisor. El bot bypasea con Admin SDK.
      allow write: if isAdminOrSupervisor();
    }

    // ========================================================================
    // REVISIONES вЂ” chofer crea solicitud, admin aprueba/rechaza
    // ========================================================================

    match /REVISIONES/{doc} {
      // Read restringido (auditoria 2026-05-17): antes cualquier
      // signedIn podia `where('dni'==otroDni').get()` y ver el
      // historico de revisiones de cualquier chofer (URLs de
      // archivos, observaciones, fechas). Ahora: admin/supervisor
      // todos, chofer solo SUS revisiones.
      allow read: if isAdminOrSupervisor()
        || (isSignedIn() && resource.data.dni == request.auth.uid);
      // Chofer crea su propia solicitud al renovar un papel. Validamos
      // que el campo `dni` del doc coincida con el UID del JWT вЂ” sin esto
      // un chofer hostil puede falsificar revisiones a nombre de otro
      // chofer o ensuciar la bandeja del supervisor con docs vacios.
      // (campo real en revision_service.dart linea 241: `'dni': dni.trim()`).
      allow create: if isSignedIn()
        && request.resource.data.dni == request.auth.uid
        && request.resource.data.keys().hasAll(['dni', 'campo',
                                                  'coleccion_destino',
                                                  'url_archivo', 'estado']);
      // Admin/supervisor aprueban o rechazan.
      allow update, delete: if isAdminOrSupervisor();
    }

    // ========================================================================
    // CHECKLISTS вЂ” chofer registra, admin lee histГіrico
    // ========================================================================

    match /CHECKLISTS/{doc} {
      // Read restringido (auditoria 2026-05-17): antes cualquier
      // signedIn podia `where('DNI'==otroDni').get()` y ver checklists
      // ajenos (foto del vehiculo, observaciones tipo "vi a tal en tal
      // lado"). Ahora: admin/supervisor/segHigiene todos (Seg e Higiene
      // los necesita para auditoria), chofer solo SUS checklists.
      allow read: if isAdminOrSupervisor()
        || isSegHigiene()
        || (isSignedIn() && resource.data.DNI == request.auth.uid);
      // El chofer crea su checklist mensual. Validamos que el campo `DNI`
      // del payload coincida con el UID вЂ” sin esto un chofer puede subir
      // checklists falsos en nombre de otro (campo real en
      // user_checklist_form_screen.dart linea 136: `'DNI': PrefsService.dni`).
      // Tambien exigimos los campos minimos para no aceptar payloads vacios.
      allow create: if isSignedIn()
        && request.resource.data.DNI == request.auth.uid
        && request.resource.data.keys().hasAll(['DNI', 'DOMINIO', 'TIPO',
                                                  'FECHA']);
      // Auditoria inmutable: NADIE edita ni borra checklists pasados.
      // YPF / Seg e Higiene los miran como evidencia legal del estado del
      // vehiculo al momento del checklist. Si el admin necesita anotar algo,
      // hay que pedir un cambio que vaya por callable (no rule).
      allow update, delete: if false;
    }

    // ========================================================================
    // AVISOS_VENCIMIENTOS вЂ” bitГЎcora de avisos manuales del admin
    // ========================================================================

    match /AVISOS_VENCIMIENTOS/{doc} {
      // ALTO (auditoria 2026-05-18): antes era `allow read: if isSignedIn()`
      // con el argumento "los datos no son sensibles". Un chofer con consola
      // Firestore custom puede listar la colecciГіn entera y ver el historial
      // operativo de TODOS los avisos: quГ© chofer recibiГі quГ© aviso, cuГЎndo,
      // por quГ© vencimiento. PII operativa de la flota completa. La app
      // Flutter NO usa esta colecciГіn (solo bot + admin), asГ­ que cerrarla
      // a admin/supervisor no rompe ningГєn flow del cliente.
      allow read: if isAdminOrSupervisor();
      // Solo admin registra (lo dispara el botГіn "Avisar por WhatsApp").
      allow write: if isAdmin();
    }

    // ========================================================================
    // COLA_WHATSAPP вЂ” el admin encola, el bot Node.js procesa via Admin SDK
    // ========================================================================

    match /COLA_WHATSAPP/{doc} {
      // El bot bypasea con Admin SDK; las rules valen solo para clientes.
      // Admin y supervisor pueden ver/encolar/reintentar/eliminar.
      allow read, write: if isAdminOrSupervisor();
    }

    // ========================================================================
    // WHATSAPP_HISTORICO вЂ” espejo de mensajes terminales (M8, 2026-05-24)
    // ========================================================================
    // Doc espejo de COLA_WHATSAPP cuando el mensaje llega a estado terminal
    // (ENVIADO o ERROR). Mismo docId. TTL 30d (campo `expira_en` + TTL
    // policy en Firestore Console). Sirve para auditar "Вїse mandГі X?"
    // cuando alguien reclama вЂ” COLA_WHATSAPP tiene TTL muy corto.
    //
    // Solo el bot escribe (vГ­a Admin SDK). Admin y supervisor LEEN, nadie
    // escribe desde la app (evitar tamper de auditorГ­a).
    match /WHATSAPP_HISTORICO/{doc} {
      allow read: if isAdminOrSupervisor();
      allow write: if false;
    }

    // ========================================================================
    // AUDITORIA_ACCIONES вЂ” bitГЎcora del admin
    // ========================================================================

    match /AUDITORIA_ACCIONES/{doc} {
      // Solo admin la lee (auditorГ­a sensible). La escritura va
      // EXCLUSIVAMENTE por la Cloud Function callable `auditLogWrite`,
      // que valida server-side el rol (ADMIN universal, SUPERVISOR
      // restringido a una whitelist reducida de acciones вЂ” asignaciones
      // y gomerГ­a) y toma `admin_dni` (== actor real, sea ADMIN o
      // SUPERVISOR) del token, no del cliente. Eso evita que un actor
      // con la consola abierta forje entradas falsas de bitГЎcora.
      allow read: if isAdmin();
      allow write: if false;
    }

    // ========================================================================
    // TELEMETRIA_HISTORICO вЂ” snapshots Volvo para reporte de consumo
    // ========================================================================

    // ========================================================================
    // META/destinatarios_notificacion вЂ” overrides editables desde la app
    // ========================================================================
    // Doc Гєnico `destinatarios_notificacion` con map { key: dni } que las
    // CFs (functions/src/comun.ts в†’ obtenerDestinatarioDni) leen con cache
    // 5 min. Si una key no existe, el caller usa el fallback hardcoded вЂ”
    // editar este doc NO puede romper nada, solo cambia destinatarios.
    // (M5, 2026-05-24.)
    match /META/destinatarios_notificacion {
      // Read amplio вЂ” admin/supervisor para que la pantalla CRUD
      // muestre los valores al supervisor tambiГ©n.
      allow read: if isAdminOrSupervisor();
      // Solo ADMIN puede cambiar destinatarios вЂ” afecta a quiГ©n recibe
      // resГєmenes que pueden incluir info sensible.
      allow write: if isAdmin();
    }

    // ========================================================================
    // META/canales_pausados вЂ” pausa temporal de categorГ­as (M9, 2026-05-24)
    // ========================================================================
    // Doc Гєnico `canales_pausados` con map { key: { hasta_iso, motivo,
    // pausado_en, pausado_por_dni } }. Los crons/triggers chequean este
    // doc (cache 5 min) antes de encolar mensajes вЂ” sirve para "vacaciones"
    // del receptor, testing de un mГіdulo, etc.
    match /META/canales_pausados {
      allow read: if isAdminOrSupervisor();
      // Solo ADMIN puede pausar/reanudar canales вЂ” el supervisor lo VE
      // pero no toca.
      allow write: if isAdmin();
    }

    match /TELEMETRIA_HISTORICO/{doc=**} {
      // Solo escribe la scheduled function `telemetriaSnapshotScheduled`
      // (cada 6 horas) vГ­a Admin SDK. La app cliente NO escribe acГЎ
      // desde 2026-04-29 вЂ” el cliente solo lee para mostrar el reporte
      // de consumo + el widget "Km recorridos" en mantenimiento.
      // 2026-05-24: abrimos read a puedeVerVolvoTableros (admin/
      // supervisor/SEG_HIGIENE) вЂ” los 3 abren la pantalla de
      // mantenimiento detalle y necesitan ver km/consumo de la unidad.
      allow read: if puedeVerVolvoTableros();
      allow write: if false;
    }

    // ========================================================================
    // STATS вЂ” agregaciones server-side para el dashboard
    // ========================================================================
    //
    // Solo escribe la scheduled function `recomputeDashboardStats`
    // (cada 5 min) vГ­a Admin SDK. El cliente lee `STATS/dashboard` para
    // pintar los KPIs (~177 docs antes, 1 doc ahora). Lectura abierta a
    // admin + supervisor (mismos roles que ven el panel).
    match /STATS/{doc} {
      allow read: if isAdminOrSupervisor();
      allow write: if false;
    }


    // ========================================================================
    // ICM_OFICIAL вЂ” ICM oficial de Sitrack (el que audita YPF) por perГ­odo
    // ========================================================================
    //
    // Doc id = perГ­odo (YYYY-MM). Lo escribe el ingestor `sitrack_sync/
    // sync_icm.py` (Admin SDK, saltea rules) una vez al dГ­a desde el portal
    // site5 de Sitrack. Reemplaza al cГЎlculo CESVI propio: trae el nГєmero
    // oficial con la ponderaciГіn por segmento vial que Sitrack tiene y
    // nosotros no. Escala invertida (mГЎs bajo = mejor). Lectura: los mismos
    // roles que ven el mГіdulo ICM. Cliente solo lee.
    match /ICM_OFICIAL/{periodo} {
      allow read: if isAdminOrSupervisor() || isSegHigiene();
      allow write: if false;
    }

    // ICM_OFICIAL_SEMANAL вЂ” mismo ICM oficial de Sitrack pero por SEMANA
    // (doc id = fecha del lunes YYYY-MM-DD). Lo escribe el mismo ingestor
    // `sync_icm.py` (Admin SDK) en cada corrida. Para el ranking semanal de
    // premios. Misma polГ­tica de lectura que ICM_OFICIAL.
    match /ICM_OFICIAL_SEMANAL/{semana} {
      allow read: if isAdminOrSupervisor() || isSegHigiene();
      allow write: if false;
    }

    // ICM_OFICIAL_CIERRE / ICM_OFICIAL_CIERRE_SEMANAL вЂ” snapshots INMUTABLES
    // de cierre (mes anterior congelado desde el dГ­a 4; semana anterior desde
    // el martes). Los crea `sync_icm.py` UNA sola vez (create-once, nunca
    // sobreescribe) para liquidar premios sobre un nГєmero que no cambie aunque
    // Sitrack reprocese. Cliente solo lee; escritura solo Admin SDK.
    match /ICM_OFICIAL_CIERRE/{periodo} {
      allow read: if isAdminOrSupervisor() || isSegHigiene();
      allow write: if false;
    }
    match /ICM_OFICIAL_CIERRE_SEMANAL/{semana} {
      allow read: if isAdminOrSupervisor() || isSegHigiene();
      allow write: if false;
    }

    // ========================================================================
    // COUNTERS вЂ” correlativos atГіmicos para impresos
    // ========================================================================
    //
    // `COUNTERS/recibos_adelanto.next` es el siguiente nГєmero de
    // comprobante de adelanto a imprimir. Se incrementa con
    // `runTransaction` desde la Cloud Function callable
    // `asignarNumeroReciboAdelanto` (Admin SDK, server-side) вЂ” el
    // plugin cloud_firestore en Windows desktop crashea con
    // `runTransaction + serverTimestamp` (bug conocido), asГ­ que
    // sacamos esa operaciГіn del cliente.
    //
    // Lectura permitida para admin/supervisor (la pantalla de
    // configuraciГіn podrГ­a mostrar "prГіximo nГєmero"); escritura
    // **bloqueada** desde el cliente вЂ” solo el Admin SDK escribe, y
    // ese bypassea las rules.
    match /COUNTERS/{doc} {
      allow read: if isAdminOrSupervisor();
      allow write: if false;
    }

    // ========================================================================
    // AVISOS_AUTOMATICOS_HISTORICO вЂ” idempotencia del cron del bot
    // ========================================================================

    match /AVISOS_AUTOMATICOS_HISTORICO/{doc=**} {
      // Solo el bot escribe (Admin SDK). La app solo lee.
      allow read: if isAdmin();
      allow write: if false;
    }

    // ========================================================================
    // RESPUESTAS_BOT_AMBIGUAS вЂ” bandeja de respuestas del bot
    // ========================================================================

    match /RESPUESTAS_BOT_AMBIGUAS/{doc=**} {
      // El bot las CREA via Admin SDK (bypassea las rules).
      // Admin/Supervisor las DESCARTAN o las CONVIERTEN en revision
      // -- ambas operaciones implican delete del doc ambiguo.
      // No hay caso de uso valido de create/update desde el cliente.
      allow read: if isAdminOrSupervisor();
      allow delete: if isAdminOrSupervisor();
      allow create, update: if false;
    }

    // ========================================================================
    // BOT_HEALTH вЂ” heartbeat del bot Node.js
    // ========================================================================
    // El bot escribe `BOT_HEALTH/main` cada ~60s (vГ­a Admin SDK) con
    // estado del cliente WA, cola, Гєltimo ciclo del cron, errores
    // recientes, etc. La pantalla "Estado del Bot" del admin lo lee en
    // vivo. Como el doc tiene info operacional (cantidad de mensajes,
    // patrГіn de errores) y el contenido podrГ­a exponer detalles internos,
    // restringimos lectura a ADMIN.

    match /BOT_HEALTH/{doc} {
      // Admin y supervisor pueden ver el estado del bot. Solo el bot
      // vГ­a Admin SDK escribe вЂ” write:false del lado cliente.
      allow read: if isAdminOrSupervisor();
      allow write: if false;
    }

    // BOT_EVENTOS вЂ” log de caГ­das/recuperaciones del bot (2026-05-08).
    // Lo popula `botHealthWatchdog` (Admin SDK). El cron `resumenBotDiario`
    // lo lee y arma resumen WhatsApp. Si en el futuro queremos mostrar
    // histГіrico de caГ­das en la pantalla "Estado del bot", admin lo lee.
    match /BOT_EVENTOS/{doc} {
      allow read: if isAdminOrSupervisor();
      allow write: if false;
    }

    // ========================================================================
    // BOT_CONTROL вЂ” kill-switch del bot (pausar / reanudar desde la app)
    // ========================================================================
    // Estado simple: `pausado: bool` + metadata (quiГ©n, cuГЎndo, motivo).
    // El bot polea este doc cada ~10s desde su src/control.js. Si estГЎ
    // pausado, salta el procesamiento de la cola y deja los docs en
    // PENDIENTE вЂ” los retoma cuando se reanude.
    //
    // Lectura: admin y supervisor (para que ambos vean el estado en la
    // pantalla 'Estado del Bot'). Escritura: solo ADMIN, porque pausar
    // detiene los envГ­os a choferes y debe ser una decisiГіn deliberada
    // del responsable, no del SUPERVISOR de turno.

    match /BOT_CONTROL/{doc} {
      allow read: if isAdminOrSupervisor();
      allow write: if isAdmin();
    }

    // ========================================================================
    // MANTENIMIENTOS_AVISADOS вЂ” idempotencia de notificaciГіn local
    // ========================================================================
    // El cliente Flutter (admin) escribe acГЎ cada vez que evalГєa el
    // estado de service de un tractor despuГ©s de un sync Volvo. Guarda
    // `ultimo_estado` (VENCIDO / URGENTE / ...) para detectar cruces y
    // no spamear notificaciones. Es estado interno operacional вЂ”
    // bajo riesgo de manipulaciГіn. Si se "falsifica", lo Гєnico que pasa
    // es que se re-notifica o no, sin afectar datos crГ­ticos.

    match /MANTENIMIENTOS_AVISADOS/{patente} {
      allow read, write: if isAdminOrSupervisor();
    }

    // ========================================================================
    // VOLVO_ALERTAS вЂ” eventos del Vehicle Alerts API (solo Cloud Function escribe)
    // ========================================================================
    // La scheduled function `volvoAlertasPoller` corre cada 5 min y popula
    // esta colecciГіn con los eventos que devuelve la Volvo Vehicle Alerts
    // API (IDLING, DISTANCE_ALERT, OVERSPEED, PTO, TELL_TALE, ALARM, etc).
    // El docId es composite e idempotente: `{vin}_{createdMs}_{tipo}`.
    //
    // El cliente puede MARCAR alertas como atendidas (escribiendo los
    // campos `atendida`, `atendida_por`, `atendida_en`) pero no puede
    // crearlas ni borrarlas вЂ” todo create/delete pasa por Admin SDK.

    match /VOLVO_ALERTAS/{doc} {
      // Lectura y "marcar atendida" disponible para admin, supervisor
      // y el rol SEG_HIGIENE (Seguridad e Higiene).
      allow read: if puedeVerVolvoTableros();
      // Update: marcar como atendida desde el tablero. Restringimos los
      // campos editables вЂ” solo `atendida*` puede cambiar. Sin esta
      // whitelist el rol puede falsificar tipo/severidad/chofer del
      // evento ya registrado (con el JWT puede modificar todo el doc).
      allow update: if puedeVerVolvoTableros()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['atendida', 'atendida_por', 'atendida_por_nombre',
                      'atendida_en', 'atendida_motivo']);
      allow create, delete: if false;
    }

    // ========================================================================
    // SITRACK_POSICIONES вЂ” Гєltima posiciГіn conocida de cada unidad
    // ========================================================================
    // Doc id = patente. Lo escribe la scheduled function
    // `sitrackPosicionPoller` cada 5 min llamando al endpoint /v2/report
    // de Sitrack. Es snapshot, no histГіrico вЂ” cada poll reemplaza
    // (con merge) los campos del doc.
    //
    // El cliente Flutter solo lee (mapa flota en vivo). Toda escritura
    // pasa por la Cloud Function (Admin SDK saltea las rules), asГ­ que
    // create/update/delete desde el cliente quedan cerrados.

    match /SITRACK_POSICIONES/{patente} {
      // Mismos roles que pueden ver tableros Volvo (admin / supervisor /
      // SEG_HIGIENE). El mapa de la flota es dato sensible вЂ” ubicaciГіn
      // del personal вЂ” y no corresponde exponerlo a roles operativos.
      allow read: if puedeVerVolvoTableros();
      allow create, update, delete: if false;
    }

    // ========================================================================
    // VOLVO_ESTADO вЂ” snapshot rFMS por unidad (poller estadoVolvoPoller)
    // ========================================================================
    // Doc id = patente. Lo escribe `estadoVolvoPoller` cada 5 min (Admin SDK,
    // saltea rules): posiciГіn, velocidad, tacГіgrafo, odo, horas_motor,
    // fuel/adblue, tell_tales del tablero. Lo leen la pantalla de
    // Mantenimiento (advertencias + telemetrГ­a) y la telemetrГ­a en vivo.
    // Mismos roles que el resto de tableros Volvo. Cliente solo lee.

    match /VOLVO_ESTADO/{patente} {
      allow read: if puedeVerVolvoTableros();
      allow create, update, delete: if false;
    }

    // ========================================================================
    // VEHICULOS_TALLER вЂ” historial completo de taller por unidad (Volvo Connect)
    // ========================================================================
    // Doc id = patente. Lo escribe el scraper `volvo_sync/sync_taller.py`
    // (Admin SDK, saltea rules) con el array `servicios` (fecha, km, taller,
    // operaciones). Lo lee la pantalla de Mantenimiento. Cliente solo lee.

    match /VEHICULOS_TALLER/{patente} {
      allow read: if puedeVerVolvoTableros();
      allow create, update, delete: if false;
    }

    // ========================================================================
    // JORNADAS_CHOFER вЂ” tracking de horas de manejo por chofer y dГ­a
    // ========================================================================
    // Doc id: `{dni}_{YYYY-MM-DD}`. Lo escribe el cron
    // `vigiladorJornadaChofer` cada 5 min con segundos acumulados de
    // manejo (>10 km/h), continuo actual, pausa actual y flags de
    // alertas enviadas. Resumen al jefe de Seg e Higiene a las 23:55.
    //
    // El cliente Flutter podrГ­a leer esto en el futuro para mostrar
    // un dashboard "horas del dГ­a por chofer" вЂ” por ahora solo el
    // server lo escribe. Lectura para los mismos roles que ven
    // tableros Volvo (admin/supervisor/SEG_HIGIENE).

    // JORNADAS_CHOFER: eliminada en cleanup definitivo 2026-05-18.
    // La coleccion vieja se borro con script (memoria: limpiar_jornadas_
    // chofer_legacy.js). Si en el futuro reaparece un doc residual, no
    // matcheara ninguna rule -> cae al `if false` del catch-all y queda
    // inaccesible. Esto es defensivo: nadie deberia escribir/leer ahi.

    // ========================================================================
    // JORNADAS вЂ” vigilador v2 (modelo bloques 3x4h + descanso 8h)
    // ========================================================================
    // Reemplaza a JORNADAS_CHOFER desde 2026-05-15. Doc id:
    // `{dni}_{ts_inicio_ms}`. Lo escribe el cron `tickVigiladorJornada`
    // cada 5 min via Admin SDK. Cliente solo lee вЂ” el dashboard del
    // tablero de Seg e Higiene muestra horas/dia por chofer.

    match /JORNADAS/{doc} {
      allow read: if puedeVerVolvoTableros();
      allow create, update, delete: if false;
    }

    // ========================================================================
    // SITRACK_EVENTOS вЂ” stream de eventos discretos del API Sitrack
    // ========================================================================
    // 1 doc por evento (docId = reportId UUID de Sitrack). Lo escribe
    // el cron `sitrackEventosPoller` cada 5 min consumiendo /files/reports.
    // Append-only вЂ” los eventos son inmutables.
    //
    // Volumen estimado: ~50-200 eventos por ciclo en rГ©gimen normal,
    // ~1-5 MB por hora. La primera invocaciГіn tras la activaciГіn bajГі
    // ~1MB de buffer acumulado.
    //
    // Lectura: roles que ven Volvo (admin/supervisor/SEG_HIGIENE) вЂ” los
    // mismos que ven JORNADAS_CHOFER y los tableros de telemetrГ­a.
    // Escritura: solo Cloud Function (Admin SDK).

    match /SITRACK_EVENTOS/{doc} {
      allow read: if puedeVerVolvoTableros();
      allow create, update, delete: if false;
    }

    // ========================================================================
    // BOT_SILENCIADOS_CHOFER вЂ” choferes silenciados (server + bot only)
    // ========================================================================
    // Doc id: DNI del chofer. Lo escribe el bot vГ­a comando WhatsApp
    // `/silenciar DNI dur [motivo]` вЂ” el admin lo usa cuando el chofer
    // estГЎ en taller / GPS roto / problema conocido para que el
    // vigilador de jornada no le mande spam cada 5 min.
    //
    // Lo lee el cron `vigiladorJornadaChofer` al iniciar cada ciclo.
    // Si `silenciado_hasta > now`, no encola avisos para ese chofer
    // (la jornada SГЌ se sigue acumulando, solo se suprime el envГ­o).
    //
    // Cliente bloqueado: el flujo correcto es por WhatsApp, no por la
    // app. Sino habrГ­a que armar UI nueva.

    match /BOT_SILENCIADOS_CHOFER/{doc} {
      allow read, write: if false;
    }

    // ========================================================================
    // META_AVISOS_NO_ID вЂ” throttle del aviso "pasГЎ el iButton" (server-only)
    // ========================================================================
    // Doc id: dni del chofer. Guarda `last_sent_at` (server timestamp) y
    // `last_patente`. Lo escribe el cron `sitrackPosicionPoller` despuГ©s
    // de encolar un aviso, y lo lee al inicio de cada ciclo para no
    // mandar otro mensaje al mismo chofer dentro de los 30 min.
    //
    // Sin esto el chofer recibirГ­a 1 mensaje cada 5 min mientras siga
    // manejando sin pasar el iButton вЂ” spam directo + riesgo de baneo
    // de WhatsApp. DecisiГіn Vecchi 2026-05-07.
    //
    // Solo el server (Admin SDK) accede. Cliente bloqueado.

    match /META_AVISOS_NO_ID/{doc} {
      allow read, write: if false;
    }

    // ========================================================================
    // META_ALERTAS_VOLVO_NOTIFICADAS вЂ” idempotencia onAlertaVolvoCreated
    // ========================================================================
    // Doc id = alertId del trigger Firestore. Garantiza que el chofer
    // reciba el mensaje UNA SOLA vez aunque el trigger se reentregue
    // (Firestore triggers son at-least-once). Lo escribe la Cloud
    // Function `onAlertaVolvoCreated` con `create()` atГіmico вЂ” si ya
    // existe, sabe que es un retry y skipea.
    //
    // Solo el server (Admin SDK) accede. Cliente bloqueado.
    match /META_ALERTAS_VOLVO_NOTIFICADAS/{doc} {
      allow read, write: if false;
    }

    // ========================================================================
    // META_LOCKS вЂ” locks de tick para crons (server-only)
    // ========================================================================
    // Doc id = nombre del cron (ej. `vigilador_jornada`, `sitrack_poller`).
    // Garantiza que dos invocaciones casi simultaneas del mismo cron no
    // corran en paralelo (Cloud Functions tiene semantica at-least-once
    // y retries de GCP). Se toma con `create()` atomico al inicio del
    // tick y se libera en `finally`. Si el proceso crashea, queda como
    // lock huerfano y el proximo tick lo roba tras N minutos.
    //
    // Solo el server (Admin SDK) accede. Cliente bloqueado.
    match /META_LOCKS/{doc} {
      allow read, write: if false;
    }

    // ========================================================================
    // LOGГЌSTICA вЂ” catГЎlogos para el futuro planeamiento de viajes
    // ========================================================================
    // Tres colecciones que arman el modelo de "rutas con precio":
    //   - EMPRESAS_LOGISTICA: clientes (origen/destino) + dadores de
    //     transporte (otros transportistas que nos ceden cargas).
    //   - UBICACIONES_LOGISTICA: puntos fГ­sicos de carga/descarga.
    //   - TARIFAS_LOGISTICA: ruta con precio + comisiГіn del dador (si
    //     aplica) + tarifa al chofer.
    //
    // Acceso: admin/supervisor lee y escribe. Otros roles bloqueados вЂ”
    // los choferes no necesitan ver tarifas (es info comercial), Seg e
    // Higiene tampoco (es parte de operaciГіn, no de monitoreo).
    //
    // Permitimos hard-delete en EMPRESAS_LOGISTICA y UBICACIONES_LOGISTICA
    // (Santiago 2026-05-12). El cliente hace check de referencias antes
    // de borrar вЂ” LogisticaService.eliminarEmpresa/eliminarUbicacion
    // cuentan tarifas y ubicaciones que las usan; si hay > 0 tira error
    // accionable y no llega al delete.
    //
    // Viajes histГіricos NO se rompen al borrar empresa/ubicaciГіn porque
    // cada viaje persistiГі `tarifa_snapshot` con los nombres cacheados
    // al momento del viaje вЂ” no apuntan por id.
    //
    // TARIFAS_LOGISTICA sigue con `allow delete: if false` (mГЎs abajo);
    // ahГ­ sГ­ se usa el flag `activa` para soft-delete porque las tarifas
    // se referencian por id desde viajes nuevos en curso.

    match /EMPRESAS_LOGISTICA/{doc} {
      allow read, create, update, delete: if isAdminOrSupervisor();
    }

    match /UBICACIONES_LOGISTICA/{doc} {
      allow read, create, update, delete: if isAdminOrSupervisor();
    }

    // TARIFAS_LOGISTICA: igual que empresas/ubicaciones, permitimos
    // delete a admin/supervisor (Santiago 2026-05-12). El cliente
    // hace check de viajes en curso (PLANEADO/EN_CURSO) que usan la
    // tarifa antes de borrar вЂ” si hay > 0, tira error accionable.
    // Viajes histГіricos siguen funcionando con su `tarifa_snapshot`.
    match /TARIFAS_LOGISTICA/{doc} {
      allow read, create, update, delete: if isAdminOrSupervisor();
    }

    // ========================================================================
    // VIAJES_LOGISTICA вЂ” ejecuciГіn y liquidaciГіn de viajes
    // ========================================================================
    // 1 doc por viaje real (carga в†’ descarga). Refiere a TARIFAS_LOGISTICA
    // con snapshot. Incluye datos delicados: tarifas, comisiones,
    // adelantos, gastos, liquidaciГіn al chofer. NO se expone al chofer
    // (decisiГіn Santiago 2026-05-09).
    //
    // Soft-delete via `activo: false` para el caso normal (operador
    // se equivocГі con un alta, lo desactiva y queda en histГіrico).
    //
    // Permitimos tambiГ©n HARD-delete a admin/supervisor (Santiago
    // 2026-05-12) вЂ” durante la etapa de testeo se generan muchos
    // viajes de prueba que ensucian el histГіrico. El flujo es:
    //   1. Tap "Eliminar" в†’ soft-delete (activo=false).
    //   2. Si el viaje ya estaba soft-deleted, tap "Eliminar
    //      definitivamente" en el detalle в†’ hard-delete.
    //
    // Si se pasa a producciГіn real, se puede volver a `delete: if false`
    // para forzar que todo quede en histГіrico.

    match /VIAJES_LOGISTICA/{doc} {
      allow read, create, update, delete: if isAdminOrSupervisor();
    }

    // ========================================================================
    // BORRADORES_VIAJE вЂ” auto-save del form de viaje multi-tramo
    // ========================================================================
    // Cada borrador es 1 doc por operador. Cuando el form arranca, intenta
    // recuperar el ultimo borrador suyo; cuando guarda OK, lo borra.
    // Sin esta rule, el patron cae al fallback `if false` y el auto-save
    // falla silenciosamente (catch en logistica_viaje_form_screen:142) вЂ”
    // bug detectado en auditoria 2026-05-17.
    //
    // Acceso admin/supervisor (mismos que usan el modulo Logistica). No
    // exponemos al chofer (no edita viajes).
    //
    // Hardening 2026-05-18: cada operador SOLO ve su propio borrador.
    // Sin este guard, si dos operadores armaban el mismo viaje en paralelo
    // se pisaban (el docId NO incluia el operador_dni en el formato viejo;
    // ahora si: {operadorDni}_{viajeIdOriginal|nuevo}, ver service:33).
    // El guard compara contra el CAMPO `operador_dni` del data вЂ” ese campo
    // es lo que el cliente realmente persiste y es defensa robusta vs
    // splitear el docId server-side.
    match /BORRADORES_VIAJE/{doc} {
      // READ/UPDATE/DELETE: solo el dueno (mirando el doc existente).
      allow read, update, delete: if isAdminOrSupervisor() &&
        resource.data.operador_dni == request.auth.uid;
      // CREATE: el doc nuevo debe llevar operador_dni == self.
      allow create: if isAdminOrSupervisor() &&
        request.resource.data.operador_dni == request.auth.uid;
    }

    // ========================================================================
    // ADELANTOS_CHOFER вЂ” entregas al chofer (de viaje o de sueldo)
    // ========================================================================
    // Creada en el refactor 2026-05-13. Hasta entonces los adelantos
    // vivГ­an embebidos en VIAJES_LOGISTICA (campos `adelantoMonto` /
    // `adelantoFecha` / `numero_recibo`). Se separГі porque muchas veces
    // se le da un adelanto al chofer SIN viaje asociado (adelanto de
    // sueldo). Ver `project_modulo_logistica.md` para mГЎs contexto.
    //
    // Datos delicados (montos, nГєmero de recibo correlativo). El chofer
    // NO los ve directo вЂ” solo el operador admin/supervisor.
    //
    // El campo `numero_recibo` lo asigna la Cloud Function callable
    // `asignarNumeroReciboAdelanto` server-side (workaround del bug de
    // runTransaction en Windows), NO el cliente. Por eso el cliente
    // puede crear/actualizar el resto pero no necesita setearlo.

    match /ADELANTOS_CHOFER/{doc} {
      allow read, create, update, delete: if isAdminOrSupervisor();
    }

    // ========================================================================
    // CACHATORE вЂ” control del bot que reserva turnos de carga YPF
    // ========================================================================
    // El bot vive 24/7 en la PC dedicada (Python, Admin SDK вЂ” bypassa rules).
    // La app escribe la selecciГіn (quГ© choferes, quГ© franja, prendido/pausado)
    // y el bot devuelve el estado en vivo. OperaciГіn: admin/supervisor (igual
    // que LogГ­stica). El chofer no entra.

    // Config global (doc `global`): interruptor maestro + hora del drop +
    // fecha objetivo. La app lo edita.
    match /CACHATORE_CONFIG/{doc} {
      allow read, write: if isAdminOrSupervisor();
    }

    // Choferes a vigilar (docId = DNI). La app crea/edita/borra; el bot
    // (Admin SDK) le escribe encima el estado en vivo sin pasar por estas
    // reglas.
    match /CACHATORE_OBJETIVOS/{dni} {
      allow read, create, update, delete: if isAdminOrSupervisor();
    }

    // Latido/estado del bot (doc `bot`). SOLO lo escribe el bot vГ­a Admin
    // SDK; la app lo lee para saber si estГЎ vivo y quГ© hace.
    match /CACHATORE_ESTADO/{doc} {
      allow read: if isAdminOrSupervisor();
      allow write: if false;
    }

    // Turnos reales de cada chofer en iTurnos (los popula el bot escaneando
    // mis_turnos de todos). La app los lee para "Turnos concretados".
    match /CACHATORE_TURNOS/{dni} {
      allow read: if isAdminOrSupervisor();
      allow write: if false;
    }

    // Buffer interno del cachatore para agrupar avisos al encargado de
    // logГ­stica cuando el drop genera 7-10 turnos seguidos. El cachatore
    // (Admin SDK) escribe acГЎ al conseguir un turno y los flushea agrupados
    // a COLA_WHATSAPP cada ciclo (ventana 90s). La app no necesita leer
    // ni escribir esto вЂ” es estado efГ­mero del worker. Deny total desde
    // cliente; admin SDK bypassa.
    match /CACHATORE_AVISOS_ENCARGADO_PENDIENTES/{doc} {
      allow read, write: if false;
    }

    // ========================================================================
    // SITRACK_IBUTTONS_HISTORICO вЂ” tramos reconstruidos del iButton fГ­sico
    // ========================================================================
    // La CF `reconstruirHistoricoIButtonsDiario` agrupa SITRACK_EVENTOS
    // del dГ­a anterior por (patente, dni) detectando cambios y persiste
    // 1 doc por tramo. Solo escribe la CF (Admin SDK). Lectura: roles
    // que ven Volvo + admin/supervisor (auditorГ­a de asignaciones).
    match /SITRACK_IBUTTONS_HISTORICO/{doc} {
      allow read: if puedeVerVolvoTableros();
      allow create, update, delete: if false;
    }

    // ========================================================================
    // VOLVO_JORNADAS_HISTORICO вЂ” jornada reconstruida por chofer y dГ­a
    // ========================================================================
    // La CF `reconstruirJornadasDiario` agrupa SITRACK_EVENTOS por
    // (driver_dni, dГ­a ART) y reconstruye tramos de manejo + paradas.
    // DocId determinГ­stico `{dni}_{YYYY-MM-DD}`. Solo escribe la CF.
    // Lectura: admin/supervisor/SEG_HIGIENE (mismo grupo que ICM).
    // El chofer ve SU PROPIA jornada (isSelf con prefijo del docId).
    match /VOLVO_JORNADAS_HISTORICO/{doc} {
      allow read: if puedeVerVolvoTableros()
                  || (isSignedIn() && doc.split('_')[0] == request.auth.uid);
      allow create, update, delete: if false;
    }

    // ========================================================================
    // ZONAS_DESCARGA вЂ” geofences configurables para mГіdulo "Descargas"
    // ========================================================================
    // El operador admin crea/edita zonas (polГ­gono o cГ­rculo) desde la app.
    // La CF `zonaDescargaPoller` las lee + cruza con SITRACK_POSICIONES para
    // mantener la cola en vivo + histГіrico de descargas. Reemplaza la
    // detecciГіn por PTO Volvo.

    match /ZONAS_DESCARGA/{slug} {
      // Admin/supervisor manejan las zonas. SEG_HIGIENE no las edita.
      allow read, create, update, delete: if isAdminOrSupervisor();
    }

    // Cola en vivo de unidades en cada zona. Solo escribe la CF (Admin SDK).
    // Lectura: roles que ven Volvo (admin/supervisor/SEG_HIGIENE) вЂ” el mГіdulo
    // "Descargas" lo lee y los 3 roles necesitan operar.
    match /ZONA_DESCARGA_COLA/{doc} {
      allow read: if puedeVerVolvoTableros();
      allow create, update, delete: if false;
    }

    // HistГіrico inmutable de descargas completadas. Lectura igual que cola.
    // Solo escribe la CF. NUNCA se modifica (auditorГ­a operativa).
    match /ZONA_DESCARGA_HISTORICO/{doc} {
      allow read: if puedeVerVolvoTableros();
      allow create, update, delete: if false;
    }

    // Pedidos one-shot del operador: "Вїeste chofer (que NO estГЎ en CACHATORE_
    // OBJETIVOS) tiene un turno preexistente sacado por la web?". La app crea
    // el doc al tappear "Verificar" en el wizard Agregar; el bot lo procesa,
    // escribe el resultado, y la app lee el resultado + borra el doc. Si la
    // app no llega a borrarlo, el bot lo limpia tras 120 s (TTL).
    //
    // Lectura/escritura: admin/supervisor (mismos roles que operan el resto
    // del mГіdulo cachatore). El bot (Admin SDK) bypassea las rules.
    match /CACHATORE_CHEQUEOS/{dni} {
      allow read, create, update, delete: if isAdminOrSupervisor();
    }

    // ========================================================================
    // EMPRESAS_EMPLEADORAS вЂ” PГіliza ART y F.931 a nivel empresa
    // ========================================================================
    // Una entrada por empresa empleadora del personal (Vecchi Ariel,
    // SucesiГіn Vecchi Carlos). DocId = CUIT. Guarda el PDF + la fecha de
    // cada documento laboral que es COMГљN a todos los empleados de esa
    // razГіn social вЂ” la PГіliza ART y el Formulario 931 son por empresa,
    // no por persona.
    //
    // Lectura: admin/supervisor/SEG_HIGIENE.
    // CRITICO (auditoria 2026-05-18): antes era `allow read: if isSignedIn()`.
    // Eso dejaba que CUALQUIER chofer leyera las URLs de PDFs de pГіlizas ART,
    // F.931 (con sueldos confidenciales) y SCVO de TODAS las razones sociales
    // вЂ” `getDownloadURL` devuelve URLs con token de larga vida que bypassean
    // las rules de Storage. Mientras no exista el campo `EMPRESA_CUIT`
    // denormalizado en EMPLEADOS para filtrar por empresa propia, restringimos
    // a admin/supervisor/SEG_HIGIENE. La pantalla MIS VENCIMIENTOS del chofer
    // ahora muestra placeholder "consultar oficina" en lugar de los datos
    // вЂ” trade-off aceptable (Vecchi 2026-05-08: estos docs NO mandan
    // WhatsApp al chofer).
    // Escritura: admin/supervisor (los mismos que ya manejan personal y
    // vencimientos). NO permitimos delete вЂ” es histГіrico.
    match /EMPRESAS_EMPLEADORAS/{cuit} {
      // Admin/supervisor/SEG_HIGIENE ven todas. El chofer ve SOLO su propia
      // empresa: comparamos el docId (CUIT) contra EMPRESA_CUIT denormalizado
      // en SU legajo (request.auth.uid == DNI == docId de EMPLEADOS). Si su
      // EMPRESA_CUIT todavГ­a no estГЎ cargado, no puede leer (la UI muestra
      // "DocumentaciГіn a cargo de la oficina"). Estos docs (PГіliza ART, F.931,
      // SCVO, libre deuda) NO tienen sueldos вЂ” Vecchi 2026-05-20.
      allow read: if isAdminOrSupervisor() || isSegHigiene()
        || (isSignedIn()
            && get(/databases/$(database)/documents/EMPLEADOS/$(request.auth.uid)).data.EMPRESA_CUIT == cuit);
      allow create, update: if isAdminOrSupervisor();
      allow delete: if false;
    }

    // ========================================================================
    // ASIGNACIONES_VEHICULO вЂ” log temporal de quiГ©n manejГі quГ© unidad
    // ========================================================================
    // Cada doc representa el perГ­odo en que un chofer manejГі una patente.
    // El doc activo (vigente) tiene `hasta == null`. Cuando hay un cambio,
    // se "cierra" el activo (`hasta = now`) y se crea uno nuevo. Permite
    // responder "ВїquiГ©n manejaba la patente X el dГ­a Y?" para multas
    // tardГ­as, atribuciГіn de eventos Volvo y disputas.
    //
    // Las escrituras pasan por `AsignacionVehiculoService` desde el cliente
    // (no hay Cloud Function dedicada). Por eso las reglas validan la
    // estructura para que el admin no pueda meter basura ni reescribir
    // historial.

    match /ASIGNACIONES_VEHICULO/{doc} {
      // Lectura: admin/supervisor. El chofer no necesita ver el log.
      allow read: if isAdminOrSupervisor();

      // Crear una nueva asignaciГіn: requiere admin/supervisor + estructura
      // mГ­nima. `hasta` debe ser null (las nuevas SIEMPRE arrancan
      // activas). `asignado_por_dni` tiene que ser quien escribe вЂ” el
      // admin no puede atribuir el cambio a otro.
      allow create: if isAdminOrSupervisor()
        && request.resource.data.asignado_por_dni == request.auth.uid
        && request.resource.data.vehiculo_id is string
        && request.resource.data.chofer_dni is string
        && request.resource.data.desde is timestamp
        && request.resource.data.hasta == null;

      // Actualizar: se permite cerrar (setear `hasta`) y, opcionalmente,
      // sumar el snapshot de odГіmetro Sitrack al cierre (para calcular
      // km recorridos por chofer en este perГ­odo). No se puede editar
      // `desde`, `chofer_dni`, `vehiculo_id`, etc вЂ” el log es inmutable
      // salvo por el cierre. Y solo si todavГ­a estaba activa.
      allow update: if isAdminOrSupervisor()
        && resource.data.hasta == null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['hasta', 'odometer_final', 'odometer_final_ts'])
        && request.resource.data.hasta is timestamp;

      // Borrar: nunca. Si hay que corregir un dato, se cierra y se
      // crea uno nuevo (audit > correcciГіn silenciosa).
      allow delete: if false;
    }

    // ========================================================================
    // ASIGNACIONES_ENGANCHE вЂ” log temporal de quГ© tractor llevГі quГ© enganche
    // ========================================================================
    // Espejo conceptual de ASIGNACIONES_VEHICULO pero para la relaciГіn
    // tractorв†”enganche. Sin esto, no se puede calcular cuГЎntos km recorriГі
    // una cubierta de enganche (la cubierta estГЎ en el enganche, los km
    // los recorre el tractor вЂ” y un enganche pasa por varios tractores).
    //
    // Las escrituras pasan por `AsignacionEngancheService` desde el cliente.
    // Mismas validaciones que ASIGNACIONES_VEHICULO: estructura mГ­nima +
    // `hasta = null` al crear + solo se permite "cerrar" (setear `hasta`).

    match /ASIGNACIONES_ENGANCHE/{doc} {
      // Lectura: admin/supervisor (incluye supervisor de gomerГ­a).
      // El chofer no necesita ver el log.
      allow read: if isAdminOrSupervisor();

      // Crear una nueva asignaciГіn: requiere admin/supervisor + estructura
      // mГ­nima + `hasta == null` (nuevas siempre arrancan activas).
      allow create: if isAdminOrSupervisor()
        && request.resource.data.asignado_por_dni == request.auth.uid
        && request.resource.data.enganche_id is string
        && request.resource.data.tractor_id is string
        && request.resource.data.desde is timestamp
        && request.resource.data.hasta == null;

      // Actualizar: se permite cerrar (`hasta`) y, opcionalmente, sumar
      // el snapshot de odГіmetro Sitrack del tractor al cierre (para
      // calcular km del tractor durante el perГ­odo del enganche, base
      // del cГЎlculo de km cubiertas Fase 2 GomerГ­a). El log es
      // inmutable en todo lo demГЎs.
      allow update: if isAdminOrSupervisor()
        && resource.data.hasta == null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['hasta', 'odometer_final', 'odometer_final_ts'])
        && request.resource.data.hasta is timestamp;

      // Borrar: nunca.
      allow delete: if false;
    }

    // ========================================================================
    // CUBIERTAS_MARCAS вЂ” catГЎlogo de marcas de cubiertas (ABM admin)
    // ========================================================================
    // Soft-delete con `activo: false` para no romper referencias histГіricas
    // en cubiertas/modelos ya cargados con esa marca.

    match /CUBIERTAS_MARCAS/{doc} {
      // Lectura: admin/supervisor + rol GOMERIA (operador del mГіdulo).
      allow read: if puedeOperarGomeria();
      // Escritura: solo admin. La gomerГ­a usa lo que el admin definiГі.
      allow write: if isAdmin();
    }

    // ========================================================================
    // CUBIERTAS_MODELOS вЂ” catГЎlogo de modelos (marca + modelo + medida + tipo_uso)
    // ========================================================================
    // El admin define quГ© modelos se manejan, sus km_vida_estimada (nueva y
    // recapada) y si son recapables. La gomerГ­a instala cubiertas de estos
    // modelos pero no edita el catГЎlogo.

    match /CUBIERTAS_MODELOS/{doc} {
      // Lectura: admin/supervisor + GOMERIA. Escritura: solo admin.
      allow read: if puedeOperarGomeria();
      allow write: if isAdmin();
    }

    // ========================================================================
    // CUBIERTAS вЂ” inventario individual (1 doc por cubierta fГ­sica)
    // ========================================================================
    // El supervisor de gomerГ­a da de alta cubiertas (al recibir nuevas del
    // proveedor) y actualiza estado/vidas/km_acumulados a travГ©s del flujo
    // de instalaciГіn/retiro/recapado.

    match /CUBIERTAS/{doc} {
      allow read: if puedeOperarGomeria();
      // Crear: el alta debe atribuirse a quien escribe (no falsificable).
      allow create: if puedeOperarGomeria()
        && request.resource.data.creado_por_dni == request.auth.uid;
      // Update / delete: admin/supervisor + GOMERIA. Las mutaciones del
      // ciclo de vida pasan por `GomeriaService` que valida estructura.
      allow update, delete: if puedeOperarGomeria();
    }

    // ========================================================================
    // CUBIERTAS_INSTALADAS вЂ” log temporal cubiertaв†”posiciГіn
    // ========================================================================
    // Espejo conceptual de ASIGNACIONES_VEHICULO pero para la relaciГіn
    // cubiertaв†”posiciГіn. La activa tiene `hasta == null`. Al retirar se
    // cierra (`hasta = now`, km_unidad_al_retirar, km_recorridos calculados).
    //
    // Las escrituras pasan por `GomeriaService` desde el cliente. Las reglas
    // validan estructura mГ­nima al crear y bloquean ediciones arbitrarias
    // del histГіrico вЂ” solo se puede "cerrar" la activa.

    match /CUBIERTAS_INSTALADAS/{doc} {
      // Lectura: admin/supervisor + GOMERIA.
      allow read: if puedeOperarGomeria();

      // Crear: requiere admin/supervisor o GOMERIA + estructura mГ­nima
      // + `hasta == null` (las nuevas siempre arrancan activas).
      // `instalado_por_dni` debe ser quien escribe.
      allow create: if puedeOperarGomeria()
        && request.resource.data.instalado_por_dni == request.auth.uid
        && request.resource.data.cubierta_id is string
        && request.resource.data.unidad_id is string
        && request.resource.data.posicion is string
        && request.resource.data.desde is timestamp
        && request.resource.data.hasta == null;

      // Actualizar: dos flujos vГЎlidos sobre la instalaciГіn activa:
      // (a) cerrar la instalaciГіn (setear `hasta`, km_*_retirar,
      //     km_recorridos, los campos de auditorГ­a del retiro y motivo).
      // (b) registrar una lectura de control (presiГіn / profundidad de
      //     banda) sin cerrar вЂ” `hasta` queda en null.
      // Cualquier otro cambio se rechaza para mantener el log inmutable.
      allow update: if puedeOperarGomeria()
        && resource.data.hasta == null
        && (
          (request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['hasta', 'km_unidad_al_retirar', 'km_recorridos',
                        'retirado_por_dni', 'retirado_por_nombre',
                        'motivo_retiro'])
            && request.resource.data.hasta is timestamp)
          ||
          (request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['ultima_presion_psi', 'ultima_profundidad_banda_mm',
                        'ultima_lectura_en', 'ultima_lectura_por_dni',
                        'ultima_lectura_por_nombre'])
            && request.resource.data.hasta == null)
        );

      // Borrar: nunca. Si hubo error, se cierra y se registra una correcciГіn.
      allow delete: if false;
    }

    // ========================================================================
    // CUBIERTAS_POSICIONES_ACTIVAS / CUBIERTAS_ACTIVAS вЂ” locks de unicidad
    // ========================================================================
    // Docs de control transaccional para garantizar que una posiciГіn
    // de unidad no tenga 2 cubiertas instaladas al mismo tiempo y que
    // una cubierta no figure activa en 2 lugares (ver
    // `GomeriaService.instalar` para el flujo completo). El cliente
    // los crea/borra dentro de la transaction de instalar/retirar.

    match /CUBIERTAS_POSICIONES_ACTIVAS/{doc} {
      allow read: if puedeOperarGomeria();
      allow create, delete: if puedeOperarGomeria();
      // No update: si la posiciГіn cambia de cubierta hay que borrar
      // y recrear (la dos operaciones son del flujo retirar+instalar
      // o del flujo "rotar").
      allow update: if false;
    }

    match /CUBIERTAS_ACTIVAS/{doc} {
      allow read: if puedeOperarGomeria();
      allow create, delete: if puedeOperarGomeria();
      allow update: if false;
    }

    // ========================================================================
    // GOMERIA_* вЂ” rediseГ±o 2026-05-29 (modelo por posiciГіn + km + marca)
    // ========================================================================
    // Sistema NUEVO, coexiste con CUBIERTAS_* hasta migrar. No serializa
    // cubiertas: los montajes referencian modelo+vida y el stock se lleva por
    // CANTIDADES (log de movimientos). Ver `MontajesService`.

    // Montaje de cubierta en una posiciГіn. Activo = `hasta == null`.
    match /GOMERIA_MONTAJES/{doc} {
      allow read: if puedeOperarGomeria();
      // Crear: montaje nuevo ACTIVO; el que lo crea es el usuario autenticado.
      allow create: if puedeOperarGomeria()
        && request.resource.data.hasta == null
        && request.resource.data.montado_por_dni == request.auth.uid;
      // Update: SOLO cerrar el montaje (retiro). No se puede reabrir ni tocar
      // la identidad (unidad/posiciГіn/modelo/vida quedan inmutables).
      allow update: if puedeOperarGomeria()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['hasta', 'km_unidad_al_retirar', 'km_recorridos',
                      'motivo_retiro', 'destino', 'retirado_por_dni',
                      'retirado_por_nombre']);
      allow delete: if false;
    }

    // Log de movimientos de stock del depГіsito. INMUTABLE (auditorГ­a +
    // base del cГЎlculo de stock por cantidades).
    match /GOMERIA_STOCK_MOVIMIENTOS/{doc} {
      allow read: if puedeOperarGomeria();
      allow create: if puedeOperarGomeria()
        && request.resource.data.responsable_dni == request.auth.uid;
      allow update, delete: if false;
    }

    // Lock de unicidad de posiciГіn. `update: if false` garantiza que una
    // posiciГіn no tenga 2 montajes activos sin necesitar runTransaction
    // (prohibido en Windows): un `set` sobre un lock existente rebota.
    match /GOMERIA_POSICIONES_ACTIVAS/{doc} {
      allow read: if puedeOperarGomeria();
      allow create, delete: if puedeOperarGomeria();
      allow update: if false;
    }

    // ========================================================================
    // CUBIERTAS_PROVEEDORES вЂ” catГЎlogo de proveedores de recapado
    // ========================================================================
    // Mismo patrГіn que CUBIERTAS_MARCAS pero ABM disponible para
    // supervisor tambiГ©n вЂ” el supervisor puede agregar un proveedor
    // nuevo on-the-fly cuando manda una cubierta a un taller que aГєn no
    // estГЎ en la lista. Soft-delete con `activo`.

    match /CUBIERTAS_PROVEEDORES/{doc} {
      allow read: if puedeOperarGomeria();
      allow write: if puedeOperarGomeria();
    }

    // ========================================================================
    // CUBIERTAS_RECAPADOS вЂ” eventos de envГ­o a recapar
    // ========================================================================
    // 1 doc por envГ­o. Se crea con `fecha_retorno = null` y `resultado = null`
    // (la cubierta queda EN_RECAPADO). Cuando vuelve, se completa con
    // `fecha_retorno`, `resultado` (RECIBIDA o DESCARTADA_POR_PROVEEDOR),
    // `costo` y `notas`. La cubierta vuelve a EN_DEPOSITO (vidas++) o
    // DESCARTADA segГєn el resultado.

    match /CUBIERTAS_RECAPADOS/{doc} {
      allow read: if puedeOperarGomeria();

      // Crear envГ­o a recapado: estructura mГ­nima + en proceso (no cerrado).
      allow create: if puedeOperarGomeria()
        && request.resource.data.enviado_por_dni == request.auth.uid
        && request.resource.data.cubierta_id is string
        && request.resource.data.proveedor is string
        && request.resource.data.fecha_envio is timestamp
        && request.resource.data.fecha_retorno == null
        && request.resource.data.resultado == null;

      // Cerrar el recapado al recibir la cubierta. Se permite setear
      // `fecha_retorno`, `resultado`, `costo`, `notas` y los campos de
      // auditorГ­a del cierre. El resto es inmutable.
      allow update: if puedeOperarGomeria()
        && resource.data.fecha_retorno == null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['fecha_retorno', 'resultado', 'costo', 'notas',
                      'cerrado_por_dni', 'cerrado_por_nombre'])
        && request.resource.data.fecha_retorno is timestamp;

      // Borrar: nunca.
      allow delete: if false;
    }

    // ========================================================================
    // CUBIERTAS_CONTROLES вЂ” histГіrico inmutable de lecturas presiГіn/banda
    // ========================================================================
    // Cada `registrarLectura()` del GomeriaService crea 1 doc acГЎ Y pisa
    // los `ultima_*` de la CUBIERTAS_INSTALADAS. La verdad histГіrica para
    // auditorГ­a / trending vive en esta colecciГіn вЂ” la "Гєltima" es solo
    // un atajo para la grilla.

    match /CUBIERTAS_CONTROLES/{doc} {
      allow read: if puedeOperarGomeria();

      // Crear: estructura mГ­nima + auth.uid coincide con
      // registrado_por_dni para no permitir suplantaciГіn.
      // Al menos uno de los 2 campos de mediciГіn debe estar.
      allow create: if puedeOperarGomeria()
        && request.resource.data.registrado_por_dni == request.auth.uid
        && request.resource.data.cubierta_id is string
        && request.resource.data.instalacion_id is string
        && request.resource.data.unidad_id is string
        && request.resource.data.posicion is string
        && request.resource.data.fecha is timestamp
        && (request.resource.data.keys().hasAny(['presion_psi', 'profundidad_banda_mm']));

      // Inmutable: nunca se modifican los controles ya creados вЂ”
      // si hubo error de carga se anota una lectura nueva.
      allow update, delete: if false;
    }

    // ========================================================================
    // CUBIERTAS_KM_PENDIENTES вЂ” cola de reconciliaciГіn de km_acumulados
    // ========================================================================
    // AuditorГ­a 2026-05-18: si una operaciГіn de retirar/rotar cubierta
    // falla al actualizar `CUBIERTAS.km_acumulados` tras 3 reintentos
    // exponenciales, el delta se persiste acГЎ para reconciliaciГіn
    // manual / cron futuro. Sin esto, los km perdidos no se recuperan
    // в†’ la cubierta parecГ­a mГЎs nueva en reportes y se descartaba
    // tarde.
    //
    // Crear: cualquier usuario que pueda operar gomerГ­a (el caller
    // del retirar/rotar). Lectura: solo admin/supervisor (para
    // diagnГіstico). Update/delete: bloqueado client-side вЂ” la
    // reconciliaciГіn va via callable o script manual.
    match /CUBIERTAS_KM_PENDIENTES/{doc} {
      allow read: if isAdminOrSupervisor();
      allow create: if puedeOperarGomeria();
      allow update, delete: if false;
    }

    // ========================================================================
    // VOLVO_SCORES_DIARIOS вЂ” scores de eco-driving (Volvo Group Scores API)
    // ========================================================================
    // La scheduled function `volvoScoresPoller` corre 1x por dГ­a a las 04:00
    // ART y popula esta colecciГіn con el score AGREGADO POR DГЌA de cada
    // vehГ­culo (docId `{patente}_{YYYY-MM-DD}`) y el de la flota completa
    // (docId `_FLEET_{YYYY-MM-DD}`).
    //
    // Sin campos de gestiГіn humana вЂ” son mГ©tricas calculadas por Volvo.
    // Idempotente: si el poller corre dos veces el mismo dГ­a, sobrescribe
    // los mismos campos sin pГ©rdida.

    match /VOLVO_SCORES_DIARIOS/{doc} {
      // Lectura admin/supervisor + SEG_HIGIENE (para pantalla
      // eco-driving). Escritura: solo el poller via Admin SDK.
      allow read: if puedeVerVolvoTableros();
      allow write: if false;
    }

    // ========================================================================
    // META вЂ” estado interno de los pollers (cursor, etc.)
    // ========================================================================
    // SubcolecciГіn de docs internos del server (cursor del poller Volvo
    // Alerts, futuros cursors de otros pollers). NingГєn cliente debe leer
    // ni escribir вЂ” todo pasa por Admin SDK.
    //
    // EXCEPCIГ“N: `META/cubiertas_counter` lo INCREMENTA `GomeriaService`
    // desde el cliente dentro de la transaction de `crearCubierta` (para
    // generar el cГіdigo `CUB-XXXX` zero-padded sin un round-trip extra a
    // una Cloud Function). Es un contador int monotГіnico вЂ” el peor caso
    // si un atacante lo manipula es que se "salten" nГєmeros de cГіdigo,
    // sin afectar integridad de datos.

    match /META/cubiertas_counter {
      allow read: if puedeOperarGomeria();
      // Create: solo si el contador arranca en 1 (primer alta del sistema).
      allow create: if puedeOperarGomeria()
        && request.resource.data.proximo == 1;
      // Update: solo +1 monotГіnico. No permite saltos ni decrementos вЂ”
      // un bug del cliente o un set manual no puede romper la secuencia.
      allow update: if puedeOperarGomeria()
        && request.resource.data.proximo == resource.data.proximo + 1;
      allow delete: if false;
    }

    match /META/{doc=**} {
      allow read, write: if false;
    }

    // ========================================================================
    // LOGIN_ATTEMPTS вЂ” rate limiting del login (solo Cloud Function)
    // ========================================================================
    // La function `loginConDni` escribe acГЎ vГ­a Admin SDK (bypasea rules).
    // NingГєn cliente debe leer/escribir directo. La colecciГіn guarda
    // intentos fallidos consecutivos por DNI (clave = hash corto del DNI)
    // y un timestamp `bloqueadoHasta` que la function consulta antes de
    // verificar la contraseГ±a.

    match /LOGIN_ATTEMPTS/{dniHash} {
      allow read, write: if false;
    }

    // ========================================================================
    // LOGIN_ATTEMPTS_IP вЂ” rate limit por IP del login (cliente bloqueado)
    // ========================================================================
    // Suplemento al rate limit por DNI (auditoria 2026-05-18): sin esto,
    // un atacante podГ­a intentar 3 passwords sobre N DNIs distintos
    // (cada uno con su propia cuota de 3 intentos) y nunca quedar
    // bloqueado por la IP origen. Threshold: 10 intentos / 5 min por IP.
    match /LOGIN_ATTEMPTS_IP/{ipHash} {
      allow read, write: if false;
    }

    // ========================================================================
    // PASS_CHANGE_ATTEMPTS вЂ” throttle de cambiarContrasenaChofer
    // ========================================================================
    // Auditoria 2026-05-18: sin esto, un device hostil con sesiГіn activa
    // podia brute-forcear la pass actual sin penalidad (bcrypt cost 10
    // в‰€ 100ms/intento). Mismo umbral que LOGIN_ATTEMPTS (3 intentos /
    // 15 min). Doc id = hash del uid (no DNI plano).
    match /PASS_CHANGE_ATTEMPTS/{uidHash} {
      allow read, write: if false;
    }

    // ========================================================================
    // FALLBACK вЂ” todo lo demГЎs bloqueado
    // ========================================================================
    // Si en el futuro alguien crea una colecciГіn nueva, queda
    // bloqueada por default hasta que se sume explГ­citamente arriba.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
